root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,tsx,json,md}]
indent_style = space
indent_size = 2

[*.kt]
indent_style = space
indent_size = 4
max_line_length = 200

[*.swift]
indent_style = space
indent_size = 2
max_line_length = 120

[*.{cpp,hpp,h,c,mm}]
indent_style = space
indent_size = 2
max_line_length = 120

