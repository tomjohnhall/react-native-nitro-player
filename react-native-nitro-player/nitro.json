{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitroplayer"],
  "ios": {
    "iosModuleName": "NitroPlayer"
  },
  "android": {
    "androidNamespace": ["nitroplayer"],
    "androidCxxLibName": "NitroPlayer"
  },
  "autolinking": {
    "PlayerQueue": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridPlayerQueue"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridPlayerQueue"
      }
    },
    "TrackPlayer": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridTrackPlayer"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridTrackPlayer"
      }
    },
    "AndroidAutoMediaLibrary": {
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridAndroidAutoMediaLibrary"
      }
    },
    "AudioDevices": {
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridAudioDevices"
      }
    },
    "AudioRoutePicker": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridAudioRoutePicker"
      }
    },
    "DownloadManager": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridDownloadManager"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridDownloadManager"
      }
    },
    "Equalizer": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridEqualizer"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridEqualizer"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
